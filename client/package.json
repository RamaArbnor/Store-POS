{
  "name": "ArbnorRama049669887",
  "version": "0.1.0",
  "author": "Arbnor Rama",
  "private": true,
  "main": "./main.js",
  "homepage": "./",
  "dependencies": {
    "axios": "^0.27.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "material-react-table": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.2",
    "react-scripts": "5.0.1",
    "sqlite3": "^5.1.6",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "concurrently --kill-others \"cross-env BROWSER=none npm start\" \"wait-on tcp:127.0.0.1:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "stop": "taskkill /F /IM electron.exe & taskkill /F /IM node.exe",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "dist": "react-scripts build && electron-builder"
  },
  "build": {
    "appId": "com.Store.app",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "build/**/*"
    ],
    "extends": null
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^7.5.0",
    "cross-env": "^7.0.3",
    "electron": "^25.4.0",
    "electron-builder": "^24.6.3",
    "wait-on": "^6.0.1"
  }
}
